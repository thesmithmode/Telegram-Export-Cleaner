# Пример файла с переменными окружения.
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с реальными паролями!

# Учётные данные администратора (если потребуется базовая аутентификация)
APP_ADMIN_USER=your_username_here
APP_ADMIN_PASSWORD=your_strong_password_here

# Redis (переопределяют значения из application.properties)
# REDIS_HOST=redis
# REDIS_PORT=6379
