# Export Worker Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ============================================================================
# TELEGRAM API CREDENTIALS
# ============================================================================
# Get these from https://my.telegram.org/apps

# Your Telegram API ID (numeric)
TELEGRAM_API_ID=123456789

# Your Telegram API Hash (string)
TELEGRAM_API_HASH=abcdef123456789abcdef123456789a

# Your phone number (with country code)
TELEGRAM_PHONE_NUMBER=+1234567890

# ============================================================================
# TELEGRAM BOT CONFIGURATION (Java Spring Boot)
# ============================================================================
# Bot token from @BotFather (required for bot to work)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Bot username without @ (shown in /start message)
TELEGRAM_BOT_USERNAME=ExportCleanerBot

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Connection settings for Redis queue

# Redis host (default: redis for Docker, localhost for local)
REDIS_HOST=redis

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis database number (default: 0)
REDIS_DB=0

# Redis password (optional, leave empty if no auth)
REDIS_PASSWORD=

# Redis queue name (default: telegram_export)
REDIS_QUEUE_NAME=telegram_export

# ============================================================================
# JAVA BOT API CONFIGURATION
# ============================================================================
# Connection settings for Java Bot backend

# Java Bot API base URL
# Use http://java-bot:8080 for Docker
# Use http://localhost:8080 for local development
JAVA_API_BASE_URL=http://java-bot:8080

# ============================================================================
# WORKER CONFIGURATION
# ============================================================================
# Export worker behavior settings

# Unique worker name (for logging and debugging)
WORKER_NAME=export-worker-1

# Maximum concurrent Pyrogram workers
MAX_WORKERS=4

# Job timeout in seconds (default: 3600 = 1 hour)
JOB_TIMEOUT=3600

# Maximum retry attempts for failed operations
MAX_RETRIES=3

# Initial retry delay in seconds (will be doubled on each retry)
RETRY_BASE_DELAY=1.0

# Maximum retry delay in seconds (cap for exponential backoff)
RETRY_MAX_DELAY=32.0

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Logging level and format

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# ============================================================================
# PYROGRAM CONFIGURATION
# ============================================================================
# Advanced Pyrogram settings

# Pyrogram String Session (production deployment via CI/CD)
# Generate once locally and add to GitHub Secrets → TELEGRAM_SESSION_STRING
# To generate: run `python get_session.py` (see export-worker/get_session.py)
# Leave empty for local development (will use file-based session)
TELEGRAM_SESSION_STRING=

# Log level for Pyrogram library: CRITICAL, ERROR, WARNING, INFO, DEBUG
PYROGRAM_LOG_LEVEL=ERROR

# ============================================================================
# NOTES
# ============================================================================
# 1. Keep this file secure - it contains credentials!
# 2. Never commit .env to git
# 3. In Docker, mount this as environment variables
# 4. For local development, source it: source .env
# 5. Telegram session file is stored in export-worker/session/
#    Delete it to force re-authentication
